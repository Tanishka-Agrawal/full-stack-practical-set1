<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Workout Details - Fitness App</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <%- include('partials/navbar') %>
  
  <div class="container mt-5">
    <div class="row">
      <div class="col-md-8 offset-md-2">
        <div class="card">
          <div class="card-header bg-primary text-white">
            <h3 class="mb-0"><%= workout.workoutType %></h3>
          </div>
          <div class="card-body">
            <div class="row mb-3">
              <div class="col-md-6">
                <p><strong>Duration:</strong> <%= workout.duration %> minutes</p>
                <p><strong>Calories Burned:</strong> <%= workout.caloriesBurned %></p>
              </div>
              <div class="col-md-6">
                <p><strong>Date:</strong> <%= new Date(workout.workoutDate).toLocaleDateString() %></p>
              </div>
            </div>

            <% if (workout.notes) { %>
              <div class="mb-3">
                <p><strong>Notes:</strong></p>
                <p><%= workout.notes %></p>
              </div>
            <% } %>
          </div>
          <div class="card-footer">
            <a href="/workouts/<%= workout._id %>/edit" class="btn btn-warning">Edit</a>
            <form action="/workouts/<%= workout._id %>?_method=DELETE" method="POST" style="display: inline;">
              <button type="submit" class="btn btn-danger" onclick="return confirm('Are you sure?')">Delete</button>
            </form>
            <a href="/workouts" class="btn btn-secondary">Back to Workouts</a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>