<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Edit Workout - Fitness App</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <%- include('partials/navbar') %>
  
  <div class="container mt-5">
    <div class="row">
      <div class="col-md-8 offset-md-2">
        <h2 class="mb-4">✏️ Edit Workout</h2>
        
        <% if (error && error.length > 0) { %>
          <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <strong>⚠️ Error!</strong> <%= error %>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
          </div>
        <% } %>
        
        <form action="/workouts/<%= workout._id %>?_method=PUT" method="POST" class="needs-validation" novalidate>
          
          <div class="mb-3">
            <label for="workoutType" class="form-label">💪 Workout Type</label>
            <input type="text" class="form-control" id="workoutType" name="workoutType" value="<%= workout.workoutType %>" disabled>
            <small class="text-muted">Workout type cannot be edited after creation.</small>
          </div>

          <div class="mb-3">
            <label for="duration" class="form-label">⏱️ Duration (minutes)</label>
            <input type="number" class="form-control" id="duration" name="duration" value="<%= workout.duration %>" required min="1" max="999">
            <div class="invalid-feedback">Please enter a valid duration between 1 and 999 minutes.</div>
          </div>

          <div class="mb-3">
            <label for="caloriesBurned" class="form-label">🔥 Calories Burned</label>
            <input type="number" class="form-control" id="caloriesBurned" name="caloriesBurned" value="<%= workout.caloriesBurned %>" required min="1" max="9999">
            <div class="invalid-feedback">Please enter a valid calorie count between 1 and 9999.</div>
          </div>

          <div class="mb-3">
            <label for="workoutDate" class="form-label">📅 Workout Date</label>
            <input type="date" class="form-control" id="workoutDate" name="workoutDate" value="<%= workout.workoutDate.toISOString().split('T')[0] %>" required>
            <div class="invalid-feedback">Please select a workout date.</div>
          </div>

          <div class="mb-3">
            <label for="notes" class="form-label">📝 Notes (Optional)</label>
            <textarea class="form-control" id="notes" name="notes" rows="4"><%= workout.notes ? workout.notes : '' %></textarea>
          </div>

          <div class="d-grid gap-2 d-md-flex justify-content-md-end">
            <a href="/workouts/<%= workout._id %>" class="btn btn-secondary">❌ Cancel</a>
            <button type="submit" class="btn btn-warning">✏️ Update Workout</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    // Bootstrap form validation
    (function() {
      'use strict';
      const forms = document.querySelectorAll('.needs-validation');
      Array.from(forms).forEach(form => {
        form.addEventListener('submit', event => {
          if (!form.checkValidity()) {
            event.preventDefault();
            event.stopPropagation();
          }
          form.classList.add('was-validated');
        }, false);
      });
    })();
  </script>
</body>
</html>